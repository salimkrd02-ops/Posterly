// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String?
  avatar    String?
  role      UserRole   @default(VIEWER)
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  events           Event[]
  templates        Template[]
  generatedPosters GeneratedPoster[]
  activityLogs     ActivityLog[]

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  EVENT_ADMIN
  DESIGNER
  DATA_ENTRY
  VIEWER
}

model Event {
  id           String   @id @default(cuid())
  name         String
  description  String?
  date         DateTime
  venue        String?
  organizerName String?
  logo         String?
  brandColors  String?  // JSON string
  fonts        String?  // JSON string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  teams           Team[]
  categories      Category[]
  programs        Program[]
  results         Result[]
  templates       Template[]
  generatedPosters GeneratedPoster[]

  @@index([userId])
  @@map("events")
}

model Team {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  logo      String?
  color     String?
  score     Float    @default(0)
  rank      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  results Result[]

  @@index([eventId])
  @@map("teams")
}

model Category {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  programs Program[]

  @@index([eventId])
  @@map("categories")
}

model Program {
  id         String   @id @default(cuid())
  eventId    String
  categoryId String
  name       String
  description String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  results    Result[]

  @@index([eventId])
  @@index([categoryId])
  @@map("programs")
}

model Result {
  id              String   @id @default(cuid())
  programId       String
  teamId          String?
  rank            Int      @default(1)
  participantName String?
  participantTeam String?
  score           Float?
  grade           String?
  remarks         String?
  photo           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  team    Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String

  @@index([programId])
  @@index([teamId])
  @@index([eventId])
  @@map("results")
}

model Template {
  id             String   @id @default(cuid())
  userId         String
  eventId        String?
  name           String
  description    String?
  type           PosterType @default(PROGRAM_RESULT)
  canvasConfig   String   // JSON string with canvas size, etc
  backgroundColor String?
  elements       String   // JSON array of elements
  preview        String?  // URL to preview thumbnail
  isPublic       Boolean  @default(false)
  isFavorite     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event            Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  generatedPosters GeneratedPoster[]

  @@index([userId])
  @@index([eventId])
  @@map("templates")
}

enum PosterType {
  PROGRAM_RESULT
  TEAM_STANDING
  FRAMED_POST
  CUSTOM
}

model GeneratedPoster {
  id          String   @id @default(cuid())
  templateId  String
  userId      String
  eventId     String?
  dataUsed    String   // JSON string of data used for generation
  fileUrl     String?
  format      String   @default("png") // png, jpg, pdf
  fileName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event    Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([userId])
  @@index([eventId])
  @@map("generated_posters")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g., "created_event", "created_template"
  details   String?  // JSON string with additional details
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("activity_logs")
}
